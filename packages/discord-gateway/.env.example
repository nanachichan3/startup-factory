# Startup Factory Discord Gateway Configuration

# Discord Bot Token (required)
# Get this from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Factory API URL (default: http://factory-api:3000 in docker, http://localhost:3001 locally)
FACTORY_API_URL=http://factory-api:3000

# Dashboard authentication credentials (must match factory-api)
DASHBOARD_USER=admin
DASHBOARD_PASS=password
