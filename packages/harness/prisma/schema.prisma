// Prisma Schema for Startup Factory
// Compatible with NocoDB — enum values have color metadata via Prisma comments
// NocoDB can read these comments when inspecting the schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// NocoDB color metadata: /// @nc.enum.color(#HEX)
// NocoDB reads these comments from the SQL DDL generated by Prisma
// ============================================================================

/// @nc.enum.color(#8888ff)

/// @nc.enum.color(#00cc66)
enum AgentStatus {
  active
  inactive
}

/// @nc.enum.color(#00cc66) "pending"
/// @nc.enum.color(#ffaa00) "in_progress"
/// @nc.enum.color(#00cc66) "completed"
/// @nc.enum.color(#ff4444) "blocked"
enum AssignmentStatus {
  pending
  in_progress
  completed
  blocked
}

/// @nc.enum.color(#00cc66) "running"
/// @nc.enum.color(#00cc66) "completed"
/// @nc.enum.color(#ff4444) "failed"
/// @nc.enum.color(#ffaa00) "cancelled"
enum WorkflowStatus {
  running
  completed
  failed
  cancelled
}

// ============================================================================
// MODELS
// ============================================================================

model Startup {
  id             String         @id @default(cuid())
  name           String
  description    String
  founderBrief   String         @default("")
  stage          String @default("idea")

  currentWorkflowId String?
  lastExecutedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artifacts        Artifact[]
  lifecycleEvents  LifecycleEvent[]
  agentAssignments AgentAssignment[]
  documents        Document[]

  @@map("startups")
}

model Artifact {
  id        String   @id @default(cuid())
  startupId String
  type      String
  title     String
  content   String   @db.Text
  agentRole String?
  iteration Int      @default(1)
  metadata  Json?
  createdAt DateTime @default(now())

  startup   Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("artifacts")
}

model LifecycleEvent {
  id         String         @id @default(cuid())
  startupId  String
  fromStage  String?
  toStage    String
  eventType  String
  metadata   Json?
  createdAt  DateTime       @default(now())

  startup    Startup        @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("lifecycle_events")
}

model Agent {
  id           String       @id @default(cuid())
  name         String       @unique
  displayName  String
  role         String
  systemPrompt String       @db.Text
  status       AgentStatus  @default(active)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  sentMessages     AgentMessage[] @relation("SentMessages")
  receivedMessages AgentMessage[] @relation("ReceivedMessages")
  assignments      AgentAssignment[]

  @@map("agents")
}

model AgentAssignment {
  id          String           @id @default(cuid())
  agentId     String
  startupId   String
  stage       String
  status      AssignmentStatus @default(pending)
  notes       String?          @db.Text
  assignedAt  DateTime         @default(now())
  completedAt DateTime?

  agent   Agent   @relation(fields: [agentId], references: [id])
  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([agentId, startupId, stage])
  @@map("agent_assignments")
}

model AgentMessage {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  type        String
  payload     Json
  workflowId  String?
  runId       String?
  createdAt   DateTime @default(now())

  sender    Agent @relation("SentMessages", fields: [senderId], references: [id])
  recipient Agent @relation("ReceivedMessages", fields: [recipientId], references: [id])

  @@map("agent_messages")
}

model WorkflowRun {
  id            String         @id @default(cuid())
  workflowId    String         @unique
  startupId     String
  type          String
  status        WorkflowStatus @default(running)
  input         Json?
  output        Json?
  error         String?        @db.Text
  startedAt     DateTime       @default(now())
  completedAt   DateTime?

  @@map("workflow_runs")
}

model Document {
  id        String   @id @default(cuid())
  startupId String
  title     String
  type      String
  content   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  startup   Startup  @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Task {
  id              String   @id @default(cuid())
  title           String
  description     String
  priority        String   @default("medium") // low, medium, high, critical
  status          String   @default("todo")    // todo, in_progress, done, blocked
  assignee        String?
  phase           String   @default("phase1")  // phase0, phase1, phase2, phase3, phase4
  estimateMinutes Int      @default(30)
  workflowRunId   String?  // optional link to WorkflowRun
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("tasks")
}
