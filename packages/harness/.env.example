# Startup Factory Harness Environment Variables
# Copy to .env and fill in the values

# ===========================================
# TEMPORAL CONFIGURATION (Cloud or Self-hosted)
# ===========================================

# For Temporal Cloud (recommended):
# Get your free namespace at: https://cloud.temporal.io
TEMPORAL_ADDRESS=your-namespace.tmprl.cloud:7233
TEMPORAL_NAMESPACE=your-namespace@your-org
TEMPORAL_API_KEY=your-temporal-cloud-api-key
TEMPORAL_TASK_QUEUE=startup-factory-queue

# For Self-hosted Temporal (alternative):
# TEMPORAL_ADDRESS=localhost:7233
# TEMPORAL_NAMESPACE=default

# ===========================================
# OPENROUTER (LLM Integration)
# ===========================================

# Get your API key at: https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================

# pg-nanachi connection (from Coolify)
# Host: x0k4w8404wckwwcswg808gco
# Port: 5432
# Database: projects
DATABASE_URL=postgresql://postgres:your-password@x0k4w8404wckwwcswg808gco:5432/projects

# ===========================================
# MEM0 (Memory Layer for AI Agents)
# ===========================================

# Mem0 Cloud API (https://mem0.ai)
MEM0_API_KEY=your-mem0-api-key

# Or self-hosted Mem0
MEM0_HOST=http://localhost:8000
MEM0_API_KEY=your-mem0-api-key

# ===========================================
# DASHBOARD AUTHENTICATION
# ===========================================

# Dashboard basic auth credentials (default: admin/password - CHANGE IN PRODUCTION)
DASHBOARD_USER=admin
DASHBOARD_PASS=change-me-in-production

# ===========================================
# REDIS (Optional - for caching/pub-sub)
# ===========================================

REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# SERVER CONFIGURATION
# ===========================================

PORT=3000
NODE_ENV=development
