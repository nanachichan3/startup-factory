# =============================================================================
# Startup Factory — Environment Variables
# =============================================================================

# Database (required — projects DB on pg-nanachi)
DATABASE_URL=postgresql://postgres:your_password@x0k4w8404wckwwcswg808gco:5432/projects
DB_HOST=x0k4w8404wckwwcswg808gco
DB_PORT=5432
DB_NAME=projects
POSTGRES_PASSWORD=your_password

# Temporal Cloud (required for workflow execution)
# Get free namespace at https://cloud.temporal.io
TEMPORAL_ADDRESS=your_namespace.tmprl.cloud:7233
TEMPORAL_NAMESPACE=your_namespace
TEMPORAL_API_KEY=your_api_key

# AI / LLM (OpenRouter — for LangGraph expert loop)
OPENROUTER_API_KEY=sk-or-v1-...

# Mem0 (optional — persistent memory for agents)
# Set after deploying Mem0 service in Coolify
# Use host.docker.internal on Coolify's internal network or the container's service name
MEM0_URL=http://host.docker.internal:5000
MEM0_API_KEY=mem0-self-hosted

# Discord Bot (optional — factory management from Discord)
# Get token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_OWNER_ID=your_discord_user_id  # Optional: restrict commands to owner

# Server
PORT=3000
NODE_ENV=production
