FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir uvicorn fastapi psutil

# Create a minimal app that just works
RUN echo 'from fastapi import FastAPI; import sys; app = FastAPI(); print("Python:", sys.version); print("Starting...")' > main.py

RUN echo 'from fastapi import FastAPI\napp = FastAPI()\n\n@app.get("/")\ndef read_root():\n    return {"status": "ok", "python": sys.version}\n\nimport sys' > main.py

EXPOSE 8000
CMD ["python", "-c", "import uvicorn; uvicorn.run('main:app', host='0.0.0.0', port=8000)"]
