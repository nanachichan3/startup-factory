FROM python:3.12-slim

# Install system dependencies for psycopg
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Patch: remove graph_store (neo4j) from DEFAULT_CONFIG if NEO4J_URI is not set
# The Mem0 server requires neo4j for graph memory by default - we patch this out
RUN if [ -z "$NEO4J_URI" ]; then \
    sed -i 's/"graph_store": {[^{]*"provider": "neo4j"[^{]*{"url": NEO4J_URI, "username": NEO4J_USERNAME, "password": NEO4J_PASSWORD},/,/ "llm":/c\ \ "llm":/' main.py; \
    fi

EXPOSE 8000

ENV PYTHONUNBUFFERED=1

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
